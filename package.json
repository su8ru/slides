{
  "name": "su8ru-slides",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "src/index.md",
  "scripts": {
    "dev": "marp --engine ./engine.mjs -s . --html",
    "build:clean": "rimraf dist",
    "build:html": "marp --engine ./engine.mjs",
    "build:ogimage": "marp --image jpeg --allow-local-files",
    "build:images": "cpx \"src/**/images/*\" dist",
    "build": "pnpm run build:clean && pnpm run build:html && pnpm run build:ogimage && pnpm run build:images"
  },
  "author": "",
  "devDependencies": {
    "@marp-team/marp-cli": "^4.3.1",
    "@shikijs/markdown-it": "^4.0.2",
    "cpx2": "^8.0.2",
    "rimraf": "^6.1.3"
  }
}
